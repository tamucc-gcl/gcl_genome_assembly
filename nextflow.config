// nextflow.config

// Pipeline parameters
params {
  // Resource limits
  max_cpus = 64
  max_memory = '300 GB'
  max_time = '96.h'
}

process {
  executor = 'slurm'
  queue = 'normal'
  scratch = true
  errorStrategy = 'retry'
  maxRetries = 2
  queueSize = 50

  // New
  withLabel: misassembly_correction {
    conda = 'bioconda::inspector'
    cpus = 64
    time = '96h'
    memory = '300 GB'
  }

  withLabel: gap_filling {
    conda = 'bioconda::tgsgapcloser'
    cpus = 64
    time = '96h'
    memory = '300 GB'
  }

  withLabel: scaffold_hic {
    conda = 'bioconda::yahs bioconda::samtools'
    cpus = 64         // Reduced from 64 - YaHS is not highly parallel
    time = '4h'       // Reduced from 96h - actual: 5m-6m24s
    memory = '300 GB'   // Reduced from 300 GB - actual: 2.9-3.4 GB
  }

  withLabel: snail_plot {
    conda = 'bioconda::blobtoolkit'
    cpus = 4
    time = '1h'
    memory = '8 GB'
  }

  // === TIER 1: CPU-BOUND, MEMORY-HUNGRY (full node) ===
  
  withLabel: hifiasm {
    conda = 'bioconda::hifiasm bioconda::gfatools'
    cpus = 64
    time = '12h'      // Reduced from 96h - actual: 1h47m-2h3m
    memory = '100 GB' // Reduced from 300 GB - actual: 73-80 GB
  }

  withLabel: merqury {
    conda = 'conda-forge::openjdk=11 bioconda::merqury'
    cpus = 64
    time = '8h'       // Reduced from 96h - actual: 2h10m-5h
    memory = '100 GB' // Reduced from 300 GB - actual: 80-84 GB
  }

  withLabel: mapping_qc {
    conda = 'bioconda::minimap2 bioconda::samtools'
    cpus = 64
    time = '8h'       // Reduced from 96h - actual: 1h-6h7m
    memory = '100 GB' // Reduced from 300 GB - actual: 80-81 GB
  }

  withLabel: map_hic {
    conda = 'bioconda::bwa-mem2 bioconda::samtools'
    cpus = 64
    time = '4h'       // Reduced from 96h - actual: 52m-1h45m
    memory = '110 GB' // Reduced from 300 GB - actual: 90-96 GB
  }

  // === TIER 2: CPU-BOUND, MODERATE MEMORY ===
  
  withLabel: busco {
    conda = 'bioconda::busco=5.3.2 bioconda::augustus=3.3'
    cpus = 64
    time = '4h'       // Reduced from 96h - actual: 18m-2h22m
    memory = '32 GB'  // Reduced from 300 GB - actual: 14-18 GB RSS
  }

  withLabel: bam_to_fastq {
    conda = 'bioconda::samtools'
    cpus = 64
    time = '4h'       // Reduced from 96h - actual: 2h-2h4m
    memory = '8 GB'   // Reduced from 300 GB - actual: 31 MB
  }

  // === TIER 3: MODERATE CPU, LOW MEMORY (half node) ===
  
  withLabel: filter_hic_bam {
    conda = 'bioconda::pairtools bioconda::samtools'
    cpus = 32         // Reduced from 64 - effective usage ~27 cores
    time = '24h'      // Reduced from 96h - actual: 11h37m-16h35m
    memory = '64 GB'  // Reduced from 300 GB - actual: 53-54 GB
  }

  withLabel: fastp {
    conda = 'bioconda::fastp'
    cpus = 16
    time = '2h'       // Reduced from 6h - actual: 47m-59m
    memory = '4 GB'   // Reduced from 32 GB - actual: 1.5 GB
  }

  // === TIER 4: LOW CPU, HIGH MEMORY (FCS processes - special case) ===
  
  withLabel: fcs {
    container = 'https://ftp.ncbi.nlm.nih.gov/genomes/TOOLS/FCS/releases/latest/fcs-gx.sif'
    containerOptions = '--bind /work/birdlab:/work/birdlab'
	queue = 'ultramem,bigmem'
    clusterOptions = '--qos=highmem'
    cpus = 32
    time = '8h'       // Reduced from 96h - actual: 1h30m-3h26m
    memory = '700 GB' // INCREASED from 300 GB - actual: 337-360 GB (!!)
  }

  withLabel: diamond {
    conda = 'bioconda::diamond conda-forge::curl conda-forge::pigz'
    cpus = 64
    time = '48h'      // Keep high for initial DB build
    memory = '150 GB' // Increased for safety during DB build
  }
  
  withName: DIAMOND_BLASTX {
    conda = 'bioconda::diamond conda-forge::curl conda-forge::pigz'
	queue = 'bigmem'
    clusterOptions = '--qos=highmem'
    cpus = 64
    time = '48h'      // Keep high for initial DB build
    memory = '700 GB' // Increased for safety during DB build
  }

  // === TIER 5: LIGHTWEIGHT PROCESSES (quarter node or less) ===
  
  withLabel: fastqc {
    conda = 'bioconda::fastqc'
    cpus = 16         // Increased from 10
    time = '2h'       // Reduced from 6h - actual: 27m-51m
    memory = '8 GB'   // Reduced from 50 GB - actual: 1.5-1.9 GB
  }

  withLabel: quast {
    conda = 'bioconda::quast'
    cpus = 16         // Increased from 10
    time = '30m'      // Reduced from 2h - actual: 1m20s-1m35s
    memory = '8 GB'   // Reduced from 16 GB - actual: 2-2.5 GB
  }

  withLabel: multiqc {
    conda = 'bioconda::multiqc'
    cpus = 4          // Increased from 2
    time = '30m'
    memory = '4 GB'
  }

  withLabel: summarize_assembly {
    conda = 'conda-forge::r-base=4.3 conda-forge::r-tidyverse conda-forge::r-jsonlite'
    cpus = 8          // Reduced from 10
    time = '30m'      // Reduced from 96h
    memory = '4 GB'   // Reduced from 16 GB
  }

  withLabel: combine_hic_qc {
    conda = 'conda-forge::r-base conda-forge::r-tidyverse conda-forge::r-rmarkdown'
    cpus = 4
    time = '30m'      // Reduced from 4h
    memory = '4 GB'   // Reduced from 16 GB
  }

  // === TIER 6: HI-C QC PROCESSES ===
  
  withLabel: hic_qc {
    conda = 'bioconda::samtools'
    cpus = 4
    time = '1h'
    memory = '4 GB'
  }
  
  withLabel: hic_contact_map {
    conda = 'bioconda::cooler bioconda::hicexplorer bioconda::pairtools'
    cpus = 32         // Reduced from 64
    time = '12h'      // Reduced from 96h - actual: 53m-7h14m
    memory = '32 GB'  // Reduced from 300 GB - actual: 14-16 GB
  }

  withLabel: hic_pair_stats {
    conda = 'bioconda::samtools conda-forge::r-base conda-forge::r-ggplot2 conda-forge::r-dplyr conda-forge::r-gridextra'
    cpus = 16         // Reduced from 32
    time = '2h'       // Reduced from 12h - actual: 6m-29m
    memory = '4 GB'   // Reduced from 128 GB - actual: 25-84 MB
  }

  withLabel: hic_coverage {
    conda = 'bioconda::samtools bioconda::bedtools conda-forge::r-base conda-forge::r-ggplot2 conda-forge::r-dplyr'
    cpus = 16         // Reduced from 32
    time = '2h'       // Reduced from 12h - actual: 13m-55m (FAILED processes)
    memory = '4 GB'   // Reduced from 128 GB - actual: 416-579 MB
  }

  withLabel: hic_liftover_pairs {
    conda = "${projectDir}/environments/hic_liftover_pairs.yaml"
    cpus = 16         // Reduced from 32
    time = '2h'       // Reduced from 12h - actual: 16m-44m
    memory = '16 GB'  // Reduced from 128 GB - actual: 2.5-11.7 GB
  }

  // === TIER 7: DATABASE & UTILITY PROCESSES ===
  
  withLabel: download_db {
    conda = 'conda-forge::curl conda-forge::tar'
    cpus = 4          // Increased from 2 for decompression
    time = '4h'
    memory = '8 GB'
  }

  withLabel: blobtools {
    conda = 'bioconda::blobtoolkit'
    cpus = 8
    time = '12h'
    memory = '32 GB'
  }

  withName: FCS_ADAPTOR {
    conda = 'conda-forge::bash conda-forge::curl coreutils'
    cpus = 8
    time = '24h'
    memory = '32 GB'
  }

  withName: FCS_BLOB_EVIDENCE_REPORT {
    conda = 'conda-forge::python=3.11'
    cpus = 2
    time = '2h'
    memory = '8 GB'
  }
}

conda {
  enabled = true
  cacheDir = '/work/birdlab/.conda_builds'
  autoActivate = true
  channels = ['bioconda', 'conda-forge', 'defaults']
  createTimeout = '2 h'
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = '/work/birdlab/singularity_cache'
  runOptions = '--cleanenv'
  envWhitelist = 'SINGULARITY_BINDPATH,SINGULARITY_LD_LIBRARY_PATH'
}

// Execution profiles
profiles {
  slurm {
    process.executor = 'slurm'
    conda.enabled = true
    singularity.enabled = true
  }
  
  local {
    process.executor = 'local'
    process.cpus = 4
    conda.enabled = true
    singularity.enabled = true
  }
  
  docker {
    docker.enabled = true
    process.container = 'quay.io/biocontainers/nextflow:latest'
  }
}

// Enable timeline and resource reports
timeline {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_timeline.html"
}

report {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_report.html"
}

trace {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_trace.txt"
}

// Enhanced DAG configuration in nextflow.config
dag {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_dag.png"
  
  // Additional styling options
  graph {
    // Graph-level attributes
    rankdir = 'TB'          // Top to bottom layout (TB, BT, LR, RL)
    bgcolor = 'white'       // Background color
    fontname = 'Arial'      // Font for the graph
    fontsize = 14           // Font size
    dpi = 300              // Resolution for PNG output
  }
  
  node {
    // Node-level attributes
    shape = 'box'           // Node shape (box, ellipse, circle, etc.)
    style = 'rounded,filled' // Node style
    fillcolor = 'lightblue' // Default fill color
    fontname = 'Arial'      // Font for nodes
    fontsize = 12           // Font size for nodes
  }
  
  edge {
    // Edge-level attributes
    color = 'gray'          // Edge color
    fontname = 'Arial'      // Font for edge labels
    fontsize = 10           // Font size for edge labels
  }
}