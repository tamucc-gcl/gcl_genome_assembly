// ============================================================================
// params {} — WS-A (parameter unification, cache-safe pass)
//
// Replaces the existing params{} block in nextflow.config AND the ~290 lines of
// params.* declarations + the six derived-map blocks in main.nf.
//
// WS-A is VALUE-PRESERVING: every value equals the current main.nf/config value,
// so rendered commands are byte-identical and `-resume` must re-run nothing.
// Behaviour changes come later:
//   • WS-B: mitohifi_genetic_code -> null (derive from kingdom); retire
//           decon_source_taxid (fold into taxid); retire phantom mitohifi_species.
//   • WS-C: hifiasm_haploid_genome_size -> null (use GenomeScope estimate);
//           retire hifiasm_nHaplotypes (-> ploidy side-channel).
// Those three are left at their CURRENT values here so WS-A stays cache-safe.
// ============================================================================
params {

    // ── Resources / run ────────────────────────────────────────────────
    max_cpus              = 64
    max_memory            = '700 GB'
    max_time              = '240.h'
    outdir                = './results'
    sample_sheet          = null
    publish_dir_mode      = 'link'
    qc_mode               = 'final_only'          // 'all_stages' | 'final_only'

    // ── Organism identity (taxid primary; rest derived, all overridable) ─
    taxid                 = null                  // sheet `taxid` column overrides per-sample
    species               = null                  // optional name override; else derived from taxid
    mitohifi_genetic_code = 2                      // WS-B: -> null (derive from kingdom)

    // ── Assembly strategy (column ▸ global param ▸ derived default) ──────
    assembler             = null
    ploidy                = null
    n_hap                 = null
    dedup                 = null
    mito_tool             = null

    // ── Shared analysis k-mer (GenomeScope + Merqury) ───────────────────
    kmer_size             = 21                     // was genomescope_kmer + merqury_k

    // ── hifiasm: overlap / error correction ─────────────────────────────
    hifiasm_kmer_length            = 51
    hifiasm_minimizer_window       = 51
    hifiasm_bloom_filter_bits      = 37
    hifiasm_kmer_drop_factor       = 5.0
    hifiasm_max_overlaps           = 100
    hifiasm_correction_rounds      = 3
    hifiasm_adapter_trim_bp        = 0
    hifiasm_max_kmer_occurrence    = 2000
    hifiasm_haploid_genome_size    = 'auto'        // WS-C: -> null (use estimate; 'auto' forces hifiasm auto)
    // ── hifiasm: assembly ───────────────────────────────────────────────
    hifiasm_cleaning_rounds        = 4
    hifiasm_contig_bubble_bp       = 10000000
    hifiasm_unitig_bubble_bp       = 0
    hifiasm_tip_unitig_reads       = 3
    hifiasm_max_overlap_drop_ratio = 0.8
    hifiasm_min_overlap_drop_ratio = 0.2
    hifiasm_post_join              = 1
    hifiasm_homozygous_coverage    = 'auto'
    hifiasm_low_quality_percent    = 70
    hifiasm_break_low_coverage     = 0
    hifiasm_break_high_coverage    = -1
    hifiasm_break_mismatch_rate    = 0.75
    hifiasm_primary                = false
    hifiasm_tip_contig_reads       = 3
    // ── hifiasm: purge-dups ─────────────────────────────────────────────
    hifiasm_purge_level            = 3
    hifiasm_purge_similarity       = 0.55
    hifiasm_purge_min_overlap      = 1
    hifiasm_purge_max_coverage     = 'auto'
    hifiasm_nHaplotypes            = 2             // WS-C: retire (-> ploidy side-channel)
    // ── hifiasm: Hi-C partition ─────────────────────────────────────────
    hifiasm_use_hic                = true
    hifiasm_hic_base_similarity    = 0.5
    hifiasm_hic_reweight_rounds    = 3
    hifiasm_hic_perturb_rounds     = 10000
    hifiasm_hic_perturb_fraction   = 0.1
    hifiasm_misjoin_detect_bp      = 500000
    // ── hifiasm: dual-scaffolding ───────────────────────────────────────
    hifiasm_dual_scaffolding       = false
    hifiasm_scaffold_max_gap_bp    = 3000000
    // ── hifiasm: telomere ───────────────────────────────────────────────
    hifiasm_telo_penalty           = 1
    hifiasm_telo_max_drop          = 2000
    hifiasm_telo_min_score         = 500

    // ── MitoHiFi ────────────────────────────────────────────────────────
    mitohifi_ref_min_bp            = 14000
    mitohifi_perc_identity         = 50
    mitohifi_cov_cutoff            = 'auto'
    mitohifi_bloom_filter          = false
    mitohifi_circular_map_dpi      = 300
    mitohifi_filter_min_identity   = 90
    mitohifi_filter_min_coverage   = 50

    // ── SPAdes ──────────────────────────────────────────────────────────
    spades_kmer_list               = '21,33,55,77'
    spades_cov_cutoff              = 'auto'
    spades_mode                    = '--isolate'
    spades_extra                   = ''
    spades_output_level            = 'scaffolds'

    // ── GenomeScope / jellyfish ─────────────────────────────────────────
    jellyfish_hash_size            = '5G'

    // ── purge_dups ──────────────────────────────────────────────────────
    run_purge_dups                 = false

    // ── redundans ───────────────────────────────────────────────────────
    run_redundans_reduction        = true
    run_redundans_scaffolding      = true
    run_redundans_gapclosing       = true
    redundans_identity             = 0.51
    redundans_overlap              = 0.80
    redundans_min_contig_bp        = 200
    redundans_joins                = 5
    redundans_linkratio            = 0.7
    redundans_limit                = 0.2
    redundans_mapq                 = 10
    redundans_iters                = 2
    redundans_preset               = 'asm5'
    redundans_index                = '4G'
    redundans_minimap2reduce       = false
    redundans_minimap2scaffold     = false
    redundans_usebwa               = false
    redundans_populate_scaffolds   = false
    redundans_norearrangements     = false
    redundans_extra                = ''

    // ── short-read / fastp ──────────────────────────────────────────────
    run_shortread_trim               = true
    shortread_fastp_cut_tail_quality = 20
    shortread_fastp_cut_tail_window  = 4
    shortread_fastp_length_required  = 30
    shortread_fastp_extra            = ''

    // ── pilon ───────────────────────────────────────────────────────────
    run_pilon                      = false
    pilon_fix                      = 'all'
    pilon_rounds                   = 1
    pilon_extra                    = ''

    // ── BUSCO ───────────────────────────────────────────────────────────
    busco_lineage                  = 'eukaryota_odb10'   // fallback; primary is per-sample from taxonomy
    busco_downloads                = '/work/birdlab/databases/busco'

    // ── inspector: contigs ──────────────────────────────────────────────
    run_inspector_contigs                   = true
    inspector_contig_base_error_check       = false      // was skip_baseerror=true (flipped)
    inspector_contig_min_depth              = null
    inspector_contig_min_contig_bp          = 10000
    inspector_contig_assemblyerror_min_bp   = 1000000
    inspector_contig_min_assembly_error_bp  = 50
    inspector_contig_max_assembly_error_bp  = 4000000
    // ── inspector: scaffolds ────────────────────────────────────────────
    run_inspector_scaffolds                  = true
    inspector_scaffold_base_error_check      = false      // was skip_baseerror=true (flipped)
    inspector_scaffold_min_depth             = null
    inspector_scaffold_min_contig_bp         = 10000
    inspector_scaffold_assemblyerror_min_bp  = 10000000
    inspector_scaffold_min_assembly_error_bp = 50
    inspector_scaffold_max_assembly_error_bp = 10000000

    // ── Hi-C mapping / contact maps ─────────────────────────────────────
    bwa_mem2_hic_args              = ''
    hic_coverage_window            = 100000
    hic_min_mapq                   = 30
    hic_resolutions                = '2500000,1000000,500000,250000,100000,50000,10000'
    hic_base_bin                   = '10000'
    hic_plot_resolutions           = '1000000,500000,250000,100000'
    run_hic_balance                = true
    hic_min_mapq_raw               = 30
    hic_min_mapq_filtered          = 1
    scaffold_min_bp                = 0

    // ── YaHS round 1 ────────────────────────────────────────────────────
    yahs_round1_min_contig_bp          = 20000
    yahs_round1_min_mapq               = 10
    yahs_round1_resolutions            = '20000,50000,100000,200000,500000,1000000,2000000,5000000,10000000,20000000,50000000,100000000,200000000'
    yahs_round1_rounds_per_resolution  = null
    yahs_round1_enzyme                 = null
    yahs_round1_contig_ec              = true            // was no_contig_ec=false (flipped)
    yahs_round1_scaffold_ec            = true            // was no_scaffold_ec=false (flipped)
    // ── YaHS round 2 ────────────────────────────────────────────────────
    yahs_round2_min_contig_bp          = 100000
    yahs_round2_min_mapq               = 20
    yahs_round2_resolutions            = '50000,100000,200000,500000,1000000,2000000,5000000,10000000,20000000,50000000,100000000'
    yahs_round2_rounds_per_resolution  = null
    yahs_round2_enzyme                 = null
    yahs_round2_contig_ec              = true            // was no_contig_ec=false (flipped)
    yahs_round2_scaffold_ec            = false           // was no_scaffold_ec=true (flipped)

    // ── finalize / contact ──────────────────────────────────────────────
    run_final_contact_maps         = true
    report_stage                   = 'final'
    finalize_min_scaffold_bp       = 1000000

    // ── pairwise alignment ──────────────────────────────────────────────
    run_pairwise_alignments        = true
    pairwise_alignment_preset      = 'asm5'
    pairwise_alignment_min_mapq    = 5
    pairwise_alignment_min_aln_bp  = 10000
    pairwise_alignment_mode        = 'within_sample'     // 'all' | 'within_sample'
    pairwise_dotplot_width         = 10
    pairwise_dotplot_height        = 10

    // ── riparian ────────────────────────────────────────────────────────
    riparian_min_aln_bp            = 50000
    riparian_min_seq_bp            = 1000000
    riparian_alpha                 = 0.45
    riparian_width                 = 14
    riparian_height                = 6

    // ── compartments ────────────────────────────────────────────────────
    compartment_resolution         = 250000
    compartment_min_contig_bp      = 5000000
    compartment_max_contigs        = 30

    // ── TADs ────────────────────────────────────────────────────────────
    tad_resolution                 = 50000
    tad_window_bp                  = 500000
    tad_min_contig_bp              = 5000000
    tad_max_contigs                = 0

    // ── telomere ────────────────────────────────────────────────────────
    telomere_motif                 = 'CCCTAA'
    telomere_window                = 10000
    telomere_min_repeats           = 10

    // ── teloclip ────────────────────────────────────────────────────────
    run_teloclip_extend            = true
    teloclip_min_clip              = 1
    teloclip_max_break             = 50
    teloclip_min_anchor            = 100
    teloclip_min_mapq              = 20
    teloclip_min_overhangs         = 1
    teloclip_max_homopolymer       = 500

    // ── tidk ────────────────────────────────────────────────────────────
    tidk_explore_minimum           = 5
    tidk_explore_maximum           = 12
    tidk_search_window             = 10000
    tidk_plot_height               = 200
    tidk_plot_width                = 1000

    // ── coverage book ───────────────────────────────────────────────────
    coverage_bin_bp                = 1000                // was bin_size
    coverage_min_bp                = 1000000             // was min_len
    coverage_min_mapq              = 5                   // was min_mapq

    // ── databases ───────────────────────────────────────────────────────
    db_base                        = '/work/birdlab/databases'
    gxdb_dir                       = "${params.db_base}/fcs-gx"
    gxdb_profile                   = 'all'
    gxdb_manifest                  = null
    gxdb_force                     = false
    diamond_dmnd                   = null
    diamond_dir                    = "${params.db_base}/diamond"
    diamond_name                   = 'proteins'
    diamond_taxdump_dir            = "${params.db_base}/ncbi_taxonomy"
    diamond_profile                = 'custom'
    diamond_fasta_url              = 'https://ftp.ncbi.nlm.nih.gov/blast/db/FASTA/nr.gz'
    diamond_taxonmap_url           = 'https://ftp.ncbi.nlm.nih.gov/pub/taxonomy/accession2taxid/prot.accession2taxid.FULL.gz'
    diamond_force                  = false

    // ── decontamination ─────────────────────────────────────────────────
    run_decon_contigs              = true                // was decon_run_on_contigs
    run_decon_scaffolds            = false               // was decon_run_on_scaffolds
    decon_source_taxid             = null                // WS-B: retire (fold into taxid)
    run_fcs_adaptor                = false               // was decon_run_fcs_adaptor
    decon_fcsadaptor_mode          = 'euk'
    decon_container_engine         = 'singularity'
    run_blobtools_evidence         = false               // was decon_make_blobtools_evidence

    // ── decontam evidence (blobtools branch) ────────────────────────────
    evidence_map_preset            = 'map-hifi'
    evidence_diamond_max_target_seqs = 1
    evidence_diamond_evalue        = 1e-25
    evidence_blob_min_contig_bp    = 1000                // was evidence_blob_min_contig_len
}

// Derived default (was the guarded computation in main.nf ~L391).
// Keep the guard so an explicit --run_scaffold_round2 still wins.
if (!params.containsKey('run_scaffold_round2') || params.run_scaffold_round2 == null) {
    params.run_scaffold_round2 = params.run_inspector_scaffolds || params.run_decon_scaffolds
}


// ============================================================================
// nextflow.config — COMPLETE process block
//
// Informed by traces from:
//   - Sde_CLim_110 (1 fish sample)
//   - 5 fish samples (Sde_CLim_110, Sde_CPla_115, Sde-CBau_104, Sde-CMat_203, Sde_CTlk_104)
//   - 3 beetle samples (golden_A01, mottled_B01, mottled_D01)
//
// Cluster: crest HPC
//   normal*:   26 nodes × 64 CPUs × 343 GB RAM (max 8 nodes at once, qos=normal)
//   bigmem:     2 nodes × 64 CPUs × 700 GB RAM (qos=highmem)
//   ultramem:   2 nodes × 64 CPUs × 1416 GB RAM (qos=highmem)
//
// Design principles:
//   - normal queue by default; attempt 1 always fits in 343 GB
//   - Dynamic memory with retry escalation to bigmem for variable processes
//   - stageInMode='copy' where scratch I/O (~1000x faster) helps random access
//   - CPUs sized to actual utilization, freeing nodes for parallelism
//   - With 8 normal nodes max, avoid requesting 64 CPUs unless truly needed
// ============================================================================

process {
  executor = 'slurm'
  queue = 'normal'
  scratch = '/scratch'
  errorStrategy = 'retry'
  maxRetries = 2
  queueSize = 50

  // DEBUG
  //withName: 'CONTACT_MAP_FINAL' {
  //  scratch = false
  //  errorStrategy = 'terminate'
  //}

  // =========================================================================
  // TIER 1: CPU-INTENSIVE, HIGH MEMORY
  // These processes genuinely use many cores and significant RAM
  // =========================================================================

  withLabel: hifiasm {
    conda = 'bioconda::hifiasm bioconda::gfatools'
    cpus = 48
    time = '4h'
    // Fish: 64-79 GB, Beetle: 59-72 GB — fits normal queue
    memory = { task.attempt == 1 ? 100.GB : 300.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  withLabel: misassembly_correction {
    conda = 'bioconda::inspector'
    cpus = 48
    time = '8h'
    // Fish: 73-83 GB, Beetle golden: 93 GB — fits normal; retry for edge cases
    memory = { task.attempt == 1 ? 110.GB : 300.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  withLabel: mapping_qc {
    conda = 'bioconda::minimap2 bioconda::samtools'
    cpus = 48
    time = '6h'
    // Fish: 71-81 GB, Beetle golden: 88 GB
    memory = '100 GB'
  }

  withLabel: map_hic {
    conda = 'bioconda::bwa-mem2 bioconda::samtools'
    cpus = 48
    time = '2h'
    // Fish: 88-96 GB, Beetle golden: 110 GB
    memory = '120 GB'
  }

  withLabel: purge_dups {
    conda = 'bioconda::purge_dups bioconda::minimap2 conda-forge::pigz'
    cpus = 48
    time = '4h'
    // Beetle golden: 92 GB peak
    memory = { task.attempt == 1 ? 110.GB : 300.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  withLabel: 'teloclip' {
    conda = 'bioconda::teloclip bioconda::minimap2 bioconda::samtools'
    cpus   = 16
    time   = '12h'
    // Minimap2 index + alignment is memory-intensive for large genomes
    // Fish (~700 Mb): ~20 GB; larger genomes scale up
    memory = '32 GB'
  }

  // =========================================================================
  // TIER 2: CPU-INTENSIVE, MODERATE MEMORY
  // =========================================================================

  withLabel: busco {
    conda = 'bioconda::busco=5.3.2 bioconda::augustus=3.3'
    cpus = 48
    time = '4h'
    // Fish: 13-24 GB, Beetle golden: 50 GB — big lineage/genome variation
    memory = { task.attempt == 1 ? 55.GB : 100.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  withLabel: bam_to_fastq {
    conda = 'bioconda::samtools'
    cpus = 32
    time = '1h'
    // Actual: <100 MB RSS everywhere
    memory = '4 GB'
  }

  // =========================================================================
  // TIER 3: MODERATE CPU, VARIABLE MEMORY
  // =========================================================================

  withLabel: merqury {
    conda = 'conda-forge::openjdk=11 bioconda::merqury'
    cpus = 8
    time = '4h'
    // Fish: 4-5 GB, Beetle golden: 16 GB — I/O bound, not CPU bound
    memory = '20 GB'
    stageInMode = 'copy'
  }

  // BUILD_MERYL_DB uses label 'merqury' but needs very different resources
  // withName takes precedence over withLabel
  withName: BUILD_MERYL_DB {
    cpus = 16
    time = '4h'
    // Fish: 31-34 GB, Beetle golden: 78 GB
    memory = { task.attempt == 1 ? 100.GB : 200.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  withLabel: filter_hic_bam {
    conda = 'bioconda::pairtools bioconda::samtools'
    cpus = 32
    time = '8h'
    // Fish: 27 GB, Beetle golden: 22 GB — streaming I/O, not CPU intensive
    memory = '50 GB'
  }

  withLabel: gap_filling {
    conda = 'bioconda::tgsgapcloser'
    cpus = 12
    time = '6h'
    // Fish: 62-82 GB, Beetle golden: 141 GB — extreme genome-size variation
    memory = { task.attempt == 1 ? 150.GB : 343.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
  }

  withLabel: pairwise_alignment {
    conda = "${projectDir}/environments/pairwise_alignment.yaml"
    cpus = 16
    time = '2h'
    // Fish (5 samples, 45 comparisons): 22-38 GB, Beetle golden: 124 GB
    memory = { task.attempt == 1 ? 150.GB : 343.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
  }

  withLabel: coverage_book {
    conda = "${projectDir}/environments/coverage_book.yaml"
    cpus = 12
    time = '8h'
    // Fish: 20-22 GB, Beetle golden: 22 GB — consistent but long runtimes
    memory = '32 GB'
    stageInMode = 'copy'
  }

  withLabel: scaffold_hic {
    conda = 'bioconda::yahs bioconda::samtools'
    cpus = 1
    time = '1h'
    // Single-threaded. Fish: 2.4-6.3 GB, Beetle: 1-1.8 GB
    memory = '8 GB'
  }

  withLabel: fastp {
    conda = 'bioconda::fastp'
    cpus = 16
    time = '2h'
    // Fish: 1.5-1.6 GB, Beetle golden: 2.3 GB
    memory = '4 GB'
  }

  withLabel: genomescope {
    conda = 'genomescope2 kmer-jellyfish'
    cpus = 16
    time = '24h'
    // jellyfish count -s allocates a large hash upfront; scales with genome size.
    memory = { task.attempt == 1 ? 100.GB : 200.GB }
    queue  = 'normal'
  }

  withLabel: redundans {
    conda          = 'bioconda::redundans'
    cpus           = 24
    time           = '24h'
    memory         = { task.attempt == 1 ? 120.GB : 240.GB }
    queue  = 'normal'
    stageInMode    = 'copy'
  }

  // =========================================================================
  // TIER 4: HIGH MEMORY SPECIAL — must use bigmem/ultramem
  // These exceed the 343 GB normal queue limit
  // =========================================================================

  withLabel: fcs {
    container = 'https://ftp.ncbi.nlm.nih.gov/genomes/TOOLS/FCS/releases/latest/fcs-gx.sif'
    containerOptions = '--bind /work/birdlab:/work/birdlab'
    queue = 'ultramem,bigmem'
    clusterOptions = '--qos=highmem'
    cpus = 32
    time = '1h'
    // Fish: 367-384 GB, Beetle: 344-386 GB — dominated by DB size, always >343 GB
    memory = '500 GB'
  }

  withLabel: diamond {
    conda = 'bioconda::diamond conda-forge::curl conda-forge::pigz'
    cpus = 64
    time = '48h'
    memory = '150 GB'
  }

  withName: DIAMOND_BLASTX {
    conda = 'bioconda::diamond conda-forge::curl conda-forge::pigz'
    queue = 'bigmem'
    clusterOptions = '--qos=highmem'
    cpus = 64
    time = '48h'
    // Needs bigmem for nr database
    memory = '700 GB'
  }

    // ---- Short-read assembly (Phase 4a) ----
  withLabel: spades {
    conda = 'bioconda::spades'
    cpus = 40
    time = '96h'
    // SPAdes' --memory cap is read from task.memory (no param).
    memory = { task.attempt == 1 ? 250.GB : 500.GB }
    queue  = { task.attempt == 1 ? 'normal' : 'bigmem,ultramem' }
    clusterOptions = { task.attempt == 1 ? '' : '--qos=highmem' }
    stageInMode = 'copy'
  }

  // pilon label (fastp + redundans labels already added / exist)
  withLabel: pilon {
      conda          = 'bioconda::pilon bioconda::bwa bioconda::samtools'
      cpus           = 64
      time           = '24h'
      memory = '1000 GB'
      queue = 'ultramem,bigmem'
      clusterOptions = '--qos=highmem'
      stageInMode    = 'copy'
  }

  // =========================================================================
  // TIER 5: LIGHTWEIGHT PROCESSES
  // Small enough to pack many per node for good parallelism
  // =========================================================================

  withLabel: 'tidk' {
    conda = 'bioconda::tidk'
    cpus   = 2
    time   = '30m'
    memory = '4 GB'
  }

   withLabel: 'mitohifi' {
       container = 'ghcr.io/marcelauliano/mitohifi:master'
       cpus = 16
       memory = '32 GB'
       time = '12h'
       queue = 'normal'
   }

   withLabel: 'filter_mito_contigs' {
       conda = 'bioconda::minimap2 bioconda::samtools'
       cpus = 8
       memory = '16 GB'
       time = '2h'
       queue = 'normal'
  }

  withLabel: 'mito_circular_map' {
        conda = 'conda-forge::pycirclize conda-forge::biopython'
        cpus = 1
        memory = '4 GB'
        time = '30m'
        queue = 'normal'
    }

  withLabel: fastqc {
    conda = 'bioconda::fastqc'
    cpus = 4
    time = { 2.h * task.attempt }   // 2h → 4h → 6h across attempts; was fixed '1h'
    // Fish: 1.5-2.3 GB, Beetle: 1.5-2.1 GB
    memory = '4 GB'
  }

  withLabel: quast {
    conda = 'bioconda::quast'
    cpus = 4
    time = '15m'
    // Single-sample: 2-6 GB; QUAST_FINAL scales with sample count (10.7 GB for 5 samples)
    memory = '16 GB'
  }

  withLabel: multiqc {
    conda = 'bioconda::multiqc'
    cpus = 4
    time = '30m'
    memory = '4 GB'
  }

  withLabel: taxonkit {
    conda  = 'taxonkit=0.15.1 csvtk'
    cpus   = 1
    memory = { 2.GB  * task.attempt }
    time   = { 30.min * task.attempt }
  }

  withLabel: snail_plot {
    conda = "${projectDir}/environments/blobtoolkit.yaml"
    cpus = 2
    time = '15m'
    // Fish: 76-369 MB, Beetle golden: 757 MB
    memory = '2 GB'
  }

  withLabel: telomere_scan {
    cpus = 1
    time = '15m'
    memory = '2 GB'
  }

  withLabel: summarize_assembly {
    conda = 'conda-forge::r-base=4.3 conda-forge::r-tidyverse conda-forge::r-jsonlite conda-forge::r-argparse'
    cpus = 4
    time = '30m'
    memory = '4 GB'
  }

  withLabel: combine_hic_qc {
    conda = 'conda-forge::r-base conda-forge::r-tidyverse conda-forge::r-rmarkdown'
    cpus = 4
    time = '30m'
    memory = '4 GB'
  }

  // =========================================================================
  // TIER 6: HI-C QC PROCESSES
  // =========================================================================

  withLabel: hic_qc {
    conda = 'bioconda::samtools'
    cpus = 2
    time = '4h'
    // BAM_METRICS: <10 MB, 13-17m (I/O streaming); PAIRS_METRICS: <10 MB, <1m
    memory = '10 GB'
  }

  withLabel: hic_contact_map {
    conda = 'bioconda::cooler bioconda::hicexplorer bioconda::pairtools'
    cpus = 4
    time = '30m'
    // Fish: 13-18 GB, Beetle golden: 31 GB
    memory = '40 GB'
  }

  withLabel: hic_pair_stats {
    conda = 'bioconda::samtools conda-forge::r-base conda-forge::r-ggplot2 conda-forge::r-dplyr conda-forge::r-gridextra'
    cpus = 4
    time = '1h'
    memory = '4 GB'
  }

  withLabel: hic_coverage {
    conda = 'bioconda::samtools bioconda::bedtools conda-forge::r-base conda-forge::r-ggplot2 conda-forge::r-dplyr'
    cpus = 4
    time = '2h'
    memory = '4 GB'
  }

  withLabel: hic_liftover_pairs {
    conda = "${projectDir}/environments/hic_liftover_pairs.yaml"
    cpus = 16
    time = '2h'
    // Actual: 2.5-12 GB
    memory = '16 GB'
  }

  // =========================================================================
  // TIER 7: DATABASE & UTILITY PROCESSES
  // =========================================================================

  withLabel: busco_download {
    conda = 'bioconda::busco'
    cpus = 2
    time = '2h'
    memory = '4 GB'
  }

  withLabel: download_db {
    conda = 'conda-forge::curl conda-forge::tar'
    cpus = 4
    time = '4h'
    memory = '8 GB'
  }

  withLabel: blobtools {
    conda = 'bioconda::blobtoolkit'
    cpus = 8
    time = '12h'
    memory = '32 GB'
  }

  withLabel: 'summary_report' {
    cpus = 4
    memory = '16 GB'
    time = '2h'
    conda = "${projectDir}/environments/report.yaml"
  }

  withLabel: 'assembly_report' {
      conda = 'python>=3.8'
      cpus = 1
      time = '30m'
      memory = '2 GB'
  }

  withLabel: 'summarize_assembly' {
      cpus = 1
      time = '30m'
      memory = '1 GB'
  }

  withLabel: 'finalize_assembly' {
      conda = 'bioconda::samtools'
      cpus = 1
      time = '1h'
      memory = '4 GB'
  }

  // =========================================================================
  // PROCESS-NAME OVERRIDES
  // For processes that share a label but need different resources
  // withName always takes precedence over withLabel
  // =========================================================================

  withName: SETUP_PAFR {
    cpus = 2
    time = '30m'
    memory = '4 GB'
  }

  withName: FCS_ADAPTOR {
    conda = 'conda-forge::bash conda-forge::curl coreutils'
    cpus = 8
    time = '24h'
    memory = '32 GB'
  }

  withName: FCS_BLOB_EVIDENCE_REPORT {
    conda = 'conda-forge::python=3.11'
    cpus = 2
    time = '2h'
    memory = '8 GB'
  }
}

conda {
  enabled = true
  cacheDir = '/work/birdlab/.conda_builds'
  autoActivate = true
  //channels = ['bioconda', 'conda-forge', 'defaults']
  conda.channels = ['conda-forge', 'bioconda', 'defaults'] 
  createTimeout = '6 h'
}

singularity {
  enabled = true
  autoMounts = true
  cacheDir = '/work/birdlab/singularity_cache'
  runOptions = '--cleanenv'
  envWhitelist = 'SINGULARITY_BINDPATH,SINGULARITY_LD_LIBRARY_PATH'
}

profiles {
  slurm {
    process.executor = 'slurm'
    conda.enabled = true
    singularity.enabled = true
  }
  local {
    process.executor = 'local'
    process.cpus = 4
    conda.enabled = true
    singularity.enabled = true
  }
  docker {
    docker.enabled = true
    process.container = 'quay.io/biocontainers/nextflow:latest'
  }
}

timeline {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_timeline.html"
}
report {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_report.html"
}
trace {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_trace.txt"
}
dag {
  enabled = true
  overwrite = true
  file = "${params.outdir}/pipeline/pipeline_dag.png"
}